{
  "info": {
    "name": "AI Scheduler",
    "_postman_id": "ai-scheduler-collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/register", "host": ["{{baseUrl}}"], "path": ["api", "auth", "register"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Verify Email",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/auth/verify-email?token=YOUR_TOKEN_HERE",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "verify-email"],
              "query": [{ "key": "token", "value": "YOUR_TOKEN_HERE" }]
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('token', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] }
          }
        },
        {
          "name": "Update Me",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Doe\"\n}"
            }
          }
        },
        {
          "name": "Delete Me",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] }
          }
        }
      ]
    },
    {
      "name": "Tasks",
      "item": [
        {
          "name": "List Tasks",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/tasks",
              "host": ["{{baseUrl}}"],
              "path": ["api", "tasks"],
              "query": [
                { "key": "status", "value": "PENDING", "disabled": true },
                { "key": "date", "value": "2026-05-11", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Task",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/tasks", "host": ["{{baseUrl}}"], "path": ["api", "tasks"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Study for Math exam\",\n  \"priorityWeight\": 9,\n  \"status\": \"PENDING\",\n  \"date\": \"2026-05-11\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"11:00:00\",\n  \"repeatWeekly\": false\n}"
            }
          }
        },
        {
          "name": "Get Task",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tasks/1", "host": ["{{baseUrl}}"], "path": ["api", "tasks", "1"] }
          }
        },
        {
          "name": "Update Task",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/tasks/1", "host": ["{{baseUrl}}"], "path": ["api", "tasks", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Study for Math exam (updated)\",\n  \"priorityWeight\": 10,\n  \"status\": \"IN_PROGRESS\",\n  \"date\": \"2026-05-11\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"12:00:00\",\n  \"repeatWeekly\": false\n}"
            }
          }
        },
        {
          "name": "Update Task Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/tasks/1/status", "host": ["{{baseUrl}}"], "path": ["api", "tasks", "1", "status"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"COMPLETED\"\n}"
            }
          }
        },
        {
          "name": "Delete Task",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/tasks/1", "host": ["{{baseUrl}}"], "path": ["api", "tasks", "1"] }
          }
        },
        {
          "name": "List Activities for Task",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/tasks/1/activities", "host": ["{{baseUrl}}"], "path": ["api", "tasks", "1", "activities"] }
          }
        }
      ]
    },
    {
      "name": "Activities",
      "item": [
        {
          "name": "List Activities",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/activities",
              "host": ["{{baseUrl}}"],
              "path": ["api", "activities"],
              "query": [
                { "key": "activityType", "value": "WORK", "disabled": true },
                { "key": "date", "value": "2026-05-11", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Activity",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/activities", "host": ["{{baseUrl}}"], "path": ["api", "activities"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"taskId\": 1,\n  \"activityType\": \"WORK\",\n  \"activityDescription\": \"Reviewed chapter 3 notes\",\n  \"date\": \"2026-05-11\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"10:30:00\"\n}"
            }
          }
        },
        {
          "name": "Get Activity",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/activities/1", "host": ["{{baseUrl}}"], "path": ["api", "activities", "1"] }
          }
        },
        {
          "name": "Update Activity",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/activities/1", "host": ["{{baseUrl}}"], "path": ["api", "activities", "1"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"taskId\": 1,\n  \"activityType\": \"WORK\",\n  \"activityDescription\": \"Reviewed chapter 4 notes\",\n  \"date\": \"2026-05-11\",\n  \"startTime\": \"09:00:00\",\n  \"endTime\": \"11:00:00\"\n}"
            }
          }
        },
        {
          "name": "Delete Activity",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/activities/1", "host": ["{{baseUrl}}"], "path": ["api", "activities", "1"] }
          }
        }
      ]
    },
    {
      "name": "Google Calendar OAuth",
      "item": [
        {
          "name": "Get Connect URL (JWT required)",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/google/calendar/connect", "host": ["{{baseUrl}}"], "path": ["auth", "google", "calendar", "connect"] }
          }
        },
        {
          "name": "OAuth Callback (called by Google)",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/auth/google/calendar/callback?code=AUTH_CODE&state=USER_ID",
              "host": ["{{baseUrl}}"],
              "path": ["auth", "google", "calendar", "callback"],
              "query": [
                { "key": "code", "value": "AUTH_CODE" },
                { "key": "state", "value": "USER_ID" }
              ]
            }
          }
        }
      ]
    }
  ]
}
