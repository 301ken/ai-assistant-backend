# AI Scheduler Backend - Environment Variables Template
# Copy this file to .env and fill in your own values

# Database Configuration (H2 default, switch to PostgreSQL for production)
SPRING_DATASOURCE_URL=jdbc:h2:mem:ai_scheduler
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# For PostgreSQL:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ai_scheduler
# SPRING_DATASOURCE_USERNAME=admin
# SPRING_DATASOURCE_PASSWORD=your-password

# OpenAI API Configuration (required for LLM features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Calendar OAuth Configuration (required for calendar sync)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8085/auth/google/calendar/callback

# Email Configuration (for verification emails)
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# Application Configuration
PORT=8085
BASE_URL=http://localhost:8085

# JWT Secret (Base64 encoded, 32+ bytes recommended)
# For development only - rotate in production
# app.jwt.secret is set in application.properties with a dev value
