# AI Scheduler Backend - Environment Variables Template
# Copy this file to .env and fill in your own values
# 
# SETUP OPTIONS:
# 1. Local H2 (in-memory, default): No extra setup - just run the app
# 2. Local PostgreSQL: Install PostgreSQL, create database, use config below
# 3. Docker + H2: docker build -t ai-scheduler . && docker run -p 8085:8085 ai-scheduler
# 4. Docker + PostgreSQL (RECOMMENDED): docker-compose up -d

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Option A: H2 In-Memory (Local Development, Single User)
# - Default option, no setup required
# - Data lost on restart
SPRING_DATASOURCE_URL=jdbc:h2:mem:ai_scheduler;DB_CLOSE_DELAY=-1
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

# Option B: PostgreSQL (Local or Docker)
# - Persistent data
# - Multi-user access
# - Production-ready
# Uncomment and modify these lines for PostgreSQL:
# SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/ai_scheduler
# SPRING_DATASOURCE_USERNAME=ai_user
# SPRING_DATASOURCE_PASSWORD=ai_password
#
# For docker-compose, use:
# SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/ai_scheduler
# SPRING_DATASOURCE_USERNAME=ai_user
# SPRING_DATASOURCE_PASSWORD=ai_password

# =============================================================================
# EXTERNAL API KEYS
# =============================================================================

# OpenAI API Key (required for LLM scheduling features)
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Google Calendar OAuth (required for calendar synchronization)
# Setup: https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8085/auth/google/calendar/callback

# =============================================================================
# EMAIL CONFIGURATION
# =============================================================================

# Gmail SMTP credentials (for sending verification emails)
# Use App Passwords if you have 2FA enabled
# Generate: https://myaccount.google.com/apppasswords
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password-here

# =============================================================================
# APPLICATION CONFIGURATION
# =============================================================================

# Server port
PORT=8085

# Public base URL (used for email links, OAuth redirects)
BASE_URL=http://localhost:8085

# =============================================================================
# SECURITY NOTES
# =============================================================================
# - Never commit .env to version control
# - Rotate all secrets before production deployment
# - Use environment variables or secrets manager in production
# - JWT secret is hardcoded in application.properties for development only
